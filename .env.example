# Backend
# Leave empty to use the default local SQLite database under ./storage.
# Project tables are managed by Alembic migrations.
LDS_API_DATABASE_URL=
LDS_API_STORAGE_DIR=./storage
LDS_API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LDS_API_MAX_IMAGE_UPLOAD_MB=15
LDS_API_THUMBNAIL_MAX_SIZE=512

# Frontend
VITE_API_BASE_URL=http://localhost:8000
